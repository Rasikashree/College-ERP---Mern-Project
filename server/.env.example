# MongoDB Atlas Connection String
# Replace <username>, <password>, <cluster>, and <db> with your actual MongoDB Atlas credentials
# Get this from: MongoDB Atlas Dashboard → Connect → Connect your application
CONNECTION_URL=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# Server Port (required)
PORT=5001

# Environment Mode
# Use "production" for deployment, "development" for local development
NODE_ENV=production

# JWT Secret (IMPORTANT: Change this for production!)
# Generate a secure secret with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=sEcReT

# Frontend URL (optional - for CORS configuration in production)
# Uncomment and set your deployed frontend domain
# FRONTEND_URL=https://your-frontend-domain.netlify.app